server:
  host: "0.0.0.0"
  port: 8700

storage:
  recordings_dir: "G:/RichIris"
  database_url: "sqlite+aiosqlite:///C:/path/to/RichIris/data/richiris.db"

ffmpeg:
  path: "C:/path/to/ffmpeg.exe"
  ffprobe_path: "C:/path/to/ffprobe.exe"
  hwaccel: "cuda"
  segment_duration: 900  # 15 minutes in seconds
  rtsp_transport: "tcp"

go2rtc:
  host: "localhost"
  port: 1984

retention:
  max_age_days: 30
  max_storage_gb: 500

logging:
  level: "DEBUG"
  json_output: false  # true for production

cameras:
  - name: "Camera 1"
    rtsp_url: "rtsp://user:password@192.168.1.100/stream1"
    sub_stream_url: "rtsp://user:password@192.168.1.100/stream2"  # optional: H.264 sub-stream for live view (zero transcode via go2rtc)
    enabled: true
  - name: "Camera 2"
    rtsp_url: "rtsp://user:password@192.168.1.101/stream1"
    sub_stream_url: ""  # leave empty to use main stream for live view
    enabled: true

trickplay:
  enabled: true
  interval: 60        # seconds between RTSP frame captures
  thumb_width: 192
  thumb_height: 108
